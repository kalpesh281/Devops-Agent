# ============================================================
# DevOps Agent — .env.example
# ============================================================
# 1. Copy to .env:     cp .env.example .env
# 2. Fill real values  (grouped by when you need them)
# 3. Lock permissions: chmod 600 .env
# .env is gitignored. NEVER commit real secrets.
#
# The file is split into 3 stages. Fill Stage 1 to start coding today.
# Stage 2 + 3 can stay placeholder until you reach those phases.
# ============================================================


# ████████████████████████████████████████████████████████████
# STAGE 1 — fill NOW to start development (terminal-first)
# ████████████████████████████████████████████████████████████
# With just these vars, you can build + unit-test all tools
# and the LangGraph agent via CLI on your Mac.
# No Telegram bot, no physical server needed yet.

# ---- GitHub ----
# Personal Access Token (classic). Scopes: repo + read:org.
# https://github.com/settings/tokens/new
# If your org uses SAML SSO, remember to "Configure SSO" on the token.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Organization handle (NOT a personal account)
GITHUB_ORG=your-org-name

# User-facing team/brand name shown in Telegram messages (welcome text,
# enrollment, etc.). Different from the bot's own name (which is set via
# @BotFather). Keep GITHUB_ORG as the technical identifier; use this for the
# friendly team name. If blank, falls back to GITHUB_ORG.
#
# Examples:
#   GITHUB_ORG=GradScalerTeam   (technical — API calls)
#   PROJECT_DISPLAY_NAME=GradScaler   (what teammates see in "DevOps Agent for ___")
PROJECT_DISPLAY_NAME=GradScaler

# ---- OpenAI (gpt-5.4-nano) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# OPENAI_MODEL=gpt-5.4-nano     # optional — override default

# ---- MongoDB ----
# The agent uses a dedicated database (MONGO_DB_NAME) — collection names are
# the canonical ones from spec §20 (servers, deployments, audit_log, etc.).
# Make sure your user has readWrite on MONGO_DB_NAME.
#
# Local dev:     mongodb://localhost:27017
# Atlas:         mongodb+srv://user:pass@cluster.xxxxx.mongodb.net
# Authenticated: mongodb://user:pw@host:27017/?authSource=admin
MONGO_URL=mongodb://localhost:27017
MONGO_DB_NAME=devops_agent

# ---- Docker Hub (for push/pull pipeline — needed once you test deploys) ----
DOCKER_HUB_USER=your-dockerhub-username
DOCKER_HUB_TOKEN=dckr_pat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ---- Runtime port ----
# The agent binds on 8100 everywhere (Mac dev + physical server).
# Reason: port 8000 on the physical server is owned by voice-auth-backend,
# so we picked 8100 once and use it universally to avoid env-specific mistakes.
AGENT_PORT=8100

# ---- Feature toggles (tune during dev) ----
ENABLE_FREE_TEXT_CHAT=true          # false → command-only mode
ENABLE_PREDEPLOY_ANALYSIS=true      # false → skip LLM Dockerfile review
ENABLE_EXPLAIN_COMMAND=true         # false → remove /explain command
ENABLE_LOG_ALERTS=true              # false → scraper runs, no Telegram alerts

# ---- Logging ----
LOG_LEVEL=INFO                      # DEBUG | INFO | WARNING | ERROR


# ████████████████████████████████████████████████████████████
# STAGE 2 — fill when wiring up Telegram (still on your Mac)
# ████████████████████████████████████████████████████████████
# After Stage 1 tools + graph tests pass, create the bot via
# @BotFather and fill these to start the Telegram UI layer.

# From @BotFather /newbot
TELEGRAM_BOT_TOKEN=0000000000:xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# User authorization: GitHub-org-gated self-enrollment.
# Teammates DM the bot, reply with their GitHub username, and the bot verifies
# membership in GITHUB_ORG. Enrolled users are stored in the Mongo `users`
# collection — no manual ID collection needed.
#
# FIRST_ADMIN_TELEGRAM_ID is the Telegram user ID that is seeded as `role: admin`
# on its first enrollment. It bootstraps admin privileges (/users revoke, etc.);
# after that, admins can promote others via `/users promote <handle>`.
# DM @userinfobot to find your own Telegram numeric ID.
FIRST_ADMIN_TELEGRAM_ID=123456789

# (Optional emergency bypass) — a comma-separated list of Telegram user IDs
# that skip the enrollment/membership check. Useful if Mongo is down or you
# need an admin back-door. Leave empty unless you specifically need it.
ALLOWED_TELEGRAM_USERS=


# ████████████████████████████████████████████████████████████
# STAGE 3 — fill only on the physical server (production)
# ████████████████████████████████████████████████████████████
# On your Mac during dev, these paths are irrelevant — you can
# leave them at defaults. When you clone the repo onto the
# physical server and run the agent there, these matter.

# Where per-project PEM keys live on the agent host.
# Folder mode 700, each .pem file mode 600.
# Convention: /devops_agent/pem/<project>.pem
# On the physical server this is a symlink to /datadrive/devops_agent/pem
# so the canonical path works but real bytes live on the big drive.
# servers.yml references each PEM by project name only (no path).
PEM_DIR=/devops_agent/pem

# Path to the server registry YAML (gitignored, mode 600)
SERVERS_YML_PATH=secrets/servers.yml
